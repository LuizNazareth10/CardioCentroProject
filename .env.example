# ---------- App ----------
APP_BASE_URL=http://localhost:3000
# segredo p/ assinar o cookie de sessão (gere com: openssl rand -base64 32)
AUTH_SECRET=troque-este-segredo-em-producao

# ---------- Backend de dados ----------
# memory  -> roda local sem nuvem (dados em memória, ótimo p/ demo)
# firestore -> usa GCP Firestore (produção)
DATA_BACKEND=memory

# ---------- GCP / Firestore (produção) ----------
GCP_PROJECT_ID=
# conteúdo do JSON da service account em base64 (ver docs/DEPLOY.md)
GOOGLE_SERVICE_ACCOUNT_B64=
# config do SDK web (para o real-time no browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- WhatsApp (Meta Cloud API) ----------
WHATSAPP_VERIFY_TOKEN=defina-um-token-de-verificacao
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# App Secret do app na Meta — usado p/ validar a assinatura HMAC do webhook
WHATSAPP_APP_SECRET=

# ---------- IA do agente (modo híbrido) ----------
ANTHROPIC_API_KEY=

# ---------- Analytics (opcional) ----------
# ID do Google Analytics 4 (ex.: G-XXXXXXXXXX). Só é carregado no navegador
# APÓS o visitante aceitar cookies no banner LGPD. Vazio = sem analytics.
NEXT_PUBLIC_GA_ID=
