# ---------- App ----------
APP_BASE_URL=http://localhost:3000
# segredo p/ assinar o cookie de sessão (gere com: openssl rand -base64 32)
AUTH_SECRET=troque-este-segredo-em-producao

# ---------- Backend de dados ----------
# memory  -> roda local sem nuvem (dados em memória, ótimo p/ demo)
# firestore -> usa GCP Firestore (produção)
DATA_BACKEND=memory

# ---------- GCP / Firestore (produção) ----------
GCP_PROJECT_ID=
# conteúdo do JSON da service account em base64 (ver docs/DEPLOY.md)
GOOGLE_SERVICE_ACCOUNT_B64=
# config do SDK web (para o real-time no browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------- WhatsApp (Meta Cloud API) ----------
WHATSAPP_VERIFY_TOKEN=defina-um-token-de-verificacao
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
# App Secret do app na Meta — usado p/ validar a assinatura HMAC do webhook
WHATSAPP_APP_SECRET=

# ---------- IA do agente (modo híbrido) ----------
ANTHROPIC_API_KEY=

# ---------- Cron (lembrete de confirmação 1 dia antes) ----------
# protege /api/cron/lembretes — a Vercel envia "Authorization: Bearer $CRON_SECRET"
# nas chamadas de cron quando esta variável está definida no projeto.
CRON_SECRET=

# ---------- Evolution API (canal de TESTE do agente, à parte da Meta) ----------
# Webhook isolado em /api/whatsapp/evolution/webhook — só processa mensagens
# vindas de EVOLUTION_NUMEROS_TESTE; qualquer outro número ou grupo é ignorado.
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
# lista separada por vírgula (sem espaços/formatação, só dígitos).
# Só esses números de CLIENTE conversam com o agente de teste.
# O número do bot (WhatsApp da Cardiocentro, ex.: 32 99112-9300) é o
# pareado na instância Evolution via QR — não entra nesta lista.
# Ex.: EVOLUTION_NUMEROS_TESTE=553288334366
EVOLUTION_NUMEROS_TESTE=
# segredo compartilhado enviado no header "x-evolution-secret" pela instância
# (configurado no webhook da instância) — protege o endpoint sem HMAC nativo.
EVOLUTION_WEBHOOK_SECRET=

# ---------- Rollout do agente (teste em produção) ----------
# Modo inicial do agente (também ajustável em runtime na tela Configurações,
# que tem prioridade sobre estes valores). full | shadow | canary | paused
AGENTE_MODO=full
# No modo canary, % de leads (0–100) atendidas pela IA — pegajoso por número.
AGENTE_CANARY_PCT=0
# Webhook (Slack ou Discord) que recebe os rascunhos no modo shadow. Vazio =
# rascunhos só nos logs do servidor.
SHADOW_WEBHOOK_URL=

# ---------- Diagnóstico ----------
# DB_METRICS=1 loga tempo e nº de documentos lidos por operação de banco
# (usado por scripts/medir-performance.ts). Deixe vazio em produção.
DB_METRICS=

# ---------- Analytics (opcional) ----------
# ID do Google Analytics 4 (ex.: G-XXXXXXXXXX). Só é carregado no navegador
# APÓS o visitante aceitar cookies no banner LGPD. Vazio = sem analytics.
NEXT_PUBLIC_GA_ID=
