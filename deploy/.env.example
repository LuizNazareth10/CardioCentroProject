# Copie para deploy/.env e preencha. NÃO versione o .env preenchido.

# URL pública HTTPS da própria Evolution nesta VPS (atrás de um proxy/SSL).
SERVER_URL=https://evo.suaclinica.com.br

# Chave da Evolution — DEVE ser a MESMA que o app usa em EVOLUTION_API_KEY.
EVOLUTION_API_KEY=troque-por-uma-chave-forte

# Senha do Postgres da stack (só interna à VPS).
POSTGRES_PASSWORD=troque-esta-senha

# Webhook do app na Vercel que recebe as mensagens.
WEBHOOK_URL=https://SEU-APP.vercel.app/api/whatsapp/evolution/webhook
